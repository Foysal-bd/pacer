{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"layout": {
			"contentSize": "900px",
			"wideSize": "1200px"
		},
		"color": {
			"palette": [
				{
					"color": "#191919",
					"name": "GH Primary BG",
					"slug": "gh-primary-bg"
				},
				{
					"color": "#2B2B2B",
					"name": "GH Secondary BG",
					"slug": "gh-secondary-bg"
				},
				{
					"color": "#E8E8E8",
					"name": "GH Menu Color",
					"slug": "gh-menu-color"
				},
				{
					"color": "#F2F2F2",
					"name": "GH Title Color",
					"slug": "gh-title-color"
				},
				{
					"color": "#C5C5C5",
					"name": "GH Paragraph Color",
					"slug": "gh-paragraph-color"
				},
				{
					"color": "#484848",
					"name": "GH Gray",
					"slug": "gh-gray"
				},
				{
					"color": "#FFFFFF",
					"name": "GH White",
					"slug": "gh-white"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "-apple-system, system-ui, Roboto, Ubuntu, Cantarell, sans-serif",
					"slug": "system",
					"name": "System"
				},
				{
					"fontFamily": "'Instrument Sans', sans-serif",
					"slug": "instrument-sans",
					"name": "Instrument Sans"
				}
			]
		},
		"custom": {
			"lineHeight": "1.8"
		}
	},
	"styles": {
		"spacing": {
			"blockGap": "0"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--instrument-sans)",
			"fontSize": "1rem",
			"lineHeight": "1.8"
		},
		"color": {
			"background": "var(--wp--preset--color--gh-white)",
			"text": "var(--wp--preset--color--gh-title-color)"
		},
		"elements": {
			"link": {
				"typography": {
					"textDecoration": "none"
				},
				"color": {
					"text": "var(--wp--preset--color--gh-title-color)"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--instrument-sans)",
					"fontSize": "2.25rem",
					"fontWeight": "600",
					"lineHeight": "1.4"
				},
				"color": {
					"text": "var(--wp--preset--color--gh-title-color)"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--instrument-sans)",
					"fontSize": "2rem",
					"fontWeight": "600",
					"lineHeight": "1.45"
				},
				"color": {
					"text": "var(--wp--preset--color--gh-title-color)"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--instrument-sans)",
					"fontSize": "1.75rem",
					"fontWeight": "600",
					"lineHeight": "1.5"
				},
				"color": {
					"text": "var(--wp--preset--color--gh-title-color)"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--instrument-sans)",
					"fontSize": "1.5rem",
					"fontWeight": "600",
					"lineHeight": "1.55"
				},
				"color": {
					"text": "var(--wp--preset--color--gh-title-color)"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--instrument-sans)",
					"fontSize": "1.125rem",
					"fontWeight": "600",
					"lineHeight": "1.6"
				},
				"color": {
					"text": "var(--wp--preset--color--gh-title-color)"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--instrument-sans)",
					"fontSize": "1rem",
					"fontWeight": "600",
					"lineHeight": "1.65"
				},
				"color": {
					"text": "var(--wp--preset--color--gh-title-color)"
				}
			}
		},
		"blocks": {
			"core/spacer": {
				"spacing": {
					"margin": {
						"top": "0"
					}
				}
			},
			"core/site-title": {
				"typography": {
					"fontSize": "3.5rem",
					"letterSpacing": "-1px",
					"lineHeight": "1"
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--instrument-sans)",
					"fontSize": "0.875rem"
				},
				"color": {
					"text": "var(--wp--preset--color--gh-title-color)"
				},
				"spacing": {
					"padding": {
						"top": ".75rem",
						"bottom": ".75rem"
					},
					"blockGap": "1.5rem"
				}
			},
			"core/paragraph": {
				"spacing": {
					"margin": {
						"top": "1.5625rem",
						"bottom": "1.5625rem"
					}
				}
			},
			"core/button": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--instrument-sans)",
					"fontSize": "0.875rem",
					"fontWeight": "600",
					"lineHeight": "2.6875rem"
				},
				"color": {
					"text": "var(--wp--preset--color--gh-white)",
					"background": "var(--wp--preset--color--gh-title-color)"
				},
				"border": {
					"radius": "0"
				}
			},
			"core/post-template": {
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				}
			},
			"core/post-featured-image": {
				"typography": {
					"lineHeight": "0"
				}
			},
			"core/social-links": {
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header-with-logo",
			"area": "header"
		},
		{
			"name": "header-with-title",
			"area": "header"
		},
		{
			"name": "footer-default",
			"area": "footer"
		},
		{
			"name": "footer-simple",
			"area": "footer"
		}
	]
}
